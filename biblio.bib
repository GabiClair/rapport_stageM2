@article{taufour_evaluation_2018,
	title = {Evaluation of the two-moment scheme {LIMA} based on microphysical observations from the {HyMeX} campaign},
	volume = {144},
	rights = {© 2018 Royal Meteorological Society},
	issn = {1477-870X},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/qj.3283},
	doi = {10.1002/qj.3283},
	abstract = {The goal of this paper is to present and evaluate the new {LIMA} (Liquid Ice Multiple Aerosols) microphysical scheme, which predicts six water species (water vapour, cloud water, rainwater, primary ice crystals, snow aggregates, and graupel). {LIMA} uses a two-moment parametrization for three hydrometeor species (ice crystals, cloud droplets, and raindrops), and is derived from the one-moment scheme {ICE}3 used daily in the {AROME} cloud-resolving operational model at Météo-France. In addition, it integrates a prognostic representation of the aerosol population. To evaluate the scheme, we simulate two well-documented Heavy Precipitation Events from the {HyMeX} (Hydrological cycle in the Mediterranean Experiment) campaign. The {LIMA} simulations are compared to {ICE}3 simulations and to a large variety of observations, such as rainfall accumulation from rain gauges, particle size distributions from disdrometers, airborne in situ measurements of ice particles, and dual-polarization radar variables. The evaluation suggests that the rain mixing ratio prognosed by {LIMA} is more realistic than that prognosed by {ICE}3. Comparisons with disdrometers and dual-polarization radars highlight the better representation of the rain microphysical variability when using {LIMA} and also its overprediction of raindrops with large diameters. The vertical composition of the convective cells is also improved by the two-moment ice parametrization in the {LIMA} scheme, which impacts the contents of the one-moment parametrized snow and graupel species. This evaluation of {LIMA} suggests ways to improve the hydrometeor representation, focusing especially on the description of the particle size distributions for different water species.},
	pages = {1398--1414},
	number = {714},
	journaltitle = {Quarterly Journal of the Royal Meteorological Society},
	author = {Taufour, Marie and Vié, Benoît and Augros, Clotilde and Boudevillain, Brice and Delanoë, Julien and Delautier, Gaëlle and Ducrocq, Véronique and Lac, Christine and Pinty, Jean-Pierre and Schwarzenböck, Alfons},
	urldate = {2026-02-26},
	date = {2018},
	langid = {english},
	note = {\_eprint: https://rmets.onlinelibrary.wiley.com/doi/pdf/10.1002/qj.3283},
	keywords = {{HyMeX}, mesoscale convective simulations, microphysics, observational data analysis},
	file = {Full Text PDF:/home/clairg/Zotero/storage/AGCRF95J/Taufour et al. - 2018 - Evaluation of the two-moment scheme LIMA based on microphysical observations from the HyMeX campaign.pdf:application/pdf;Snapshot:/home/clairg/Zotero/storage/SCSPIQBG/qj.html:text/html},
}

